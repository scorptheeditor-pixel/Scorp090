rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isVerified() {
      // Allow Google Sign-in accounts as they are verified
      return isAuthenticated() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Projects
    function isValidProject(data) {
      return data.keys().hasAll(['userId', 'title', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 4 &&
             data.userId is string && data.userId == request.auth.uid && data.userId.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /projects/{projectId} {
      allow read: if isVerified() && isValidId(projectId) && existing().userId == request.auth.uid;
      allow list: if isVerified() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidId(projectId) && 
                    isValidProject(incoming()) && 
                    incoming().createdAt == request.time && 
                    incoming().updatedAt == request.time;
      allow update: if isVerified() && isValidId(projectId) && 
                    isValidProject(incoming()) && 
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'updatedAt']);
      allow delete: if isVerified() && isValidId(projectId) && existing().userId == request.auth.uid;

      // Messages Subcollection
      function isValidMessage(data) {
        return data.keys().hasAll(['role', 'content', 'createdAt']) &&
               data.keys().size() == 3 &&
               data.role is string && (data.role == 'user' || data.role == 'model' || data.role == 'system') &&
               data.content is string && data.content.size() <= 10000 &&
               data.createdAt is timestamp;
      }

      match /messages/{messageId} {
        allow read: if isVerified() && isValidId(projectId) && isValidId(messageId) && get(/databases/$(database)/documents/projects/$(projectId)).data.userId == request.auth.uid;
        allow list: if isVerified() && isValidId(projectId) && get(/databases/$(database)/documents/projects/$(projectId)).data.userId == request.auth.uid;
        allow create: if isVerified() && isValidId(projectId) && isValidId(messageId) &&
                      get(/databases/$(database)/documents/projects/$(projectId)).data.userId == request.auth.uid &&
                      isValidMessage(incoming()) &&
                      incoming().createdAt == request.time;
        allow update, delete: if false; // Messages are immutable
      }
    }

    // Generations
    function isValidGeneration(data) {
      return data.keys().hasAll(['userId', 'prompt', 'imageUrl', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.userId is string && data.userId == request.auth.uid && data.userId.size() <= 128 &&
             data.prompt is string && data.prompt.size() <= 2000 &&
             data.imageUrl is string && data.imageUrl.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    match /generations/{generationId} {
      allow read: if isVerified() && isValidId(generationId) && existing().userId == request.auth.uid;
      allow list: if isVerified() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidId(generationId) &&
                    isValidGeneration(incoming()) &&
                    incoming().createdAt == request.time;
      allow update, delete: if false; // Generations are immutable
    }
  }
}
